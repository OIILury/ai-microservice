# Configuration de l'API Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT_SECONDS=60

# Paramètres du modèle
CORRECTION_TEMPERATURE=0.0
NAVIGATION_TEMPERATURE=0.0
REFORMULATION_TEMPERATURE=0.3

# Configuration du serveur FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# "development" : monte l'endpoint /api/metrics/* (dashboard de métriques) et stocke
#                 le texte brut (entrée/sortie, tronqué à 500 caractères) en base pour
#                 le debug local.
# "production"  : /api/metrics/* n'est pas monté (404, absent même de /docs) et aucun
#                 texte utilisateur n'est stocké, seules les métriques de performance
#                 (latence, tokens/s, etc.) le sont. C'est la valeur par défaut si cette
#                 variable est absente : ne jamais déployer sur maurice sans vérifier
#                 que cette valeur est bien "production" (ou absente).
ENVIRONMENT=development
# Configuration de l'API Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_TIMEOUT_SECONDS=60

# Paramètres du modèle
CORRECTION_TEMPERATURE=0.0
NAVIGATION_TEMPERATURE=0.0
REFORMULATION_TEMPERATURE=0.3

# Configuration du serveur FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
